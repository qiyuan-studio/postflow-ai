# ===================================================
# PostFlow AI - 环境变量配置
# ===================================================
# 复制此文件为 .env 并填入你的配置
# cp .env.example .env

# === 数据库 ===
# 开发环境使用 SQLite（默认）
DATABASE_URL="file:./dev.db"
# 生产环境使用 PostgreSQL（推荐）
# DATABASE_URL="postgresql://user:password@host:5432/postflow"

# === NextAuth.js (认证) ===
AUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars"
AUTH_URL="http://localhost:3000"

# === OpenAI (AI内容生成) ===
# 从 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY="sk-your-openai-api-key"

# === Stripe (支付) ===
# 从 https://dashboard.stripe.com/test/apikeys 获取测试密钥
NEXT_PUBLIC_STRIPE_KEY="pk_test_xxxxxxxx"
STRIPE_SECRET_KEY="sk_test_xxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxx"
# 在 Stripe Dashboard 创建产品后填入价格ID
# STRIPE_PRO_PRICE_ID="price_pro"
# STRIPE_ENTERPRISE_PRICE_ID="price_enterprise"

# === Resend (邮件) - 可选 ===
# RESEND_API_KEY="re_xxxxxxxx"

# === 社交媒体 OAuth - 可选 ===
# 各平台的 OAuth App 凭证（发布功能需要）
# X_CLIENT_ID=""
# X_CLIENT_SECRET=""
# LINKEDIN_CLIENT_ID=""
# LINKEDIN_CLIENT_SECRET=""
# TIKTOK_CLIENT_KEY=""
# TIKTOK_CLIENT_SECRET=""
